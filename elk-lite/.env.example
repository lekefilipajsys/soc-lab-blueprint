# Elastic version checked against official docs on 2026-06-23.
STACK_VERSION=9.4.2

# Elasticsearch and Kibana are local-only by default.
ES_BIND=127.0.0.1
ES_PORT=9200
KIBANA_BIND=127.0.0.1
KIBANA_PORT=5601

# Logstash is intentionally reachable from lab VMs through the Docker host.
# Restrict these ports with the host firewall to private lab subnets only.
LOGSTASH_JSON_PORT=5514
LOGSTASH_SYSLOG_PORT=5515

